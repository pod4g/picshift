---
import { SUPPORTED_LOCALES, LOCALE_CONFIG } from '../i18n/config';
import type { Locale } from '../i18n/config';
import { htmlCanonicalUrl } from '../lib/htmlCanonicalUrl';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  lang?: Locale;
  pagePath?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  noAlternate?: boolean;
  ogArticleMeta?: {
    publishedTime: string;
    modifiedTime: string;
    author: string;
    tags: string[];
  };
}

const { title, description, canonical, lang = 'en', pagePath = '/', ogType = 'website', ogImage, noAlternate = false, ogArticleMeta } = Astro.props;
const siteBase = 'https://picshift.app';
const rawCanonical =
  canonical || (lang === 'en' ? `${siteBase}${pagePath}` : `${siteBase}/${lang}${pagePath === '/' ? '/' : pagePath}`);
const canonicalUrl = htmlCanonicalUrl(rawCanonical);
const ogImageUrl = ogImage ? `${siteBase}${ogImage}` : `${siteBase}/og-image.png`;
const ogImageType = ogImageUrl.endsWith('.webp') ? 'image/webp' : ogImageUrl.endsWith('.jpg') || ogImageUrl.endsWith('.jpeg') ? 'image/jpeg' : 'image/png';

const localeConfig = LOCALE_CONFIG[lang];
const hrefLang = localeConfig.hrefLang;
const dir = localeConfig.dir;

// OG locale mapping
const OG_LOCALE: Record<string, string> = {
  en: 'en_US', zh: 'zh_CN', 'zh-Hant': 'zh_TW', es: 'es_ES',
  fr: 'fr_FR', de: 'de_DE', ja: 'ja_JP', ko: 'ko_KR',
  pt: 'pt_BR', ru: 'ru_RU', ar: 'ar_SA', it: 'it_IT',
};

// Build hreflang alternate links
const normalizedPath = pagePath === '/' ? '' : pagePath;

function buildHrefLangUrl(locale: Locale): string {
  const raw = locale === 'en' ? `${siteBase}${pagePath}` : `${siteBase}/${locale}${normalizedPath || '/'}`;
  return htmlCanonicalUrl(raw);
}

// Organization schema for home page
const isHome = pagePath === '/';
const orgSchema = isHome ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'PicShift',
  url: siteBase,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description: description,
  image: ogImageUrl,
  inLanguage: SUPPORTED_LOCALES.map((l) => LOCALE_CONFIG[l].hrefLang),
}) : null;
const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'PicShift',
  url: siteBase,
  inLanguage: SUPPORTED_LOCALES.map((l) => LOCALE_CONFIG[l].hrefLang),
});

import '../styles/global.css';
---

<!doctype html>
<html lang={hrefLang} dir={dir} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Theme: apply dark/light class before paint to avoid flash -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('picshift_theme');
        if (t === 'light') {
          document.documentElement.classList.remove('dark');
        }
        // Default is dark (class already set on html)
      })();
    </script>
    <!-- Language auto-detection and redirect -->
    <script is:inline>
      (function() {
        var path = window.location.pathname;
        var englishOnly = ['/blog'];
        var skipRedirect = englishOnly.some(function(p) { return path.startsWith(p + '/') || path === p; });
        if (skipRedirect) return;
        var stored = localStorage.getItem('picshift_lang');
        if (stored && stored !== 'en') {
          var locales = ['zh','zh-Hant','es','fr','de','ja','ko','pt','ru','ar','it'];
          var isOnLocale = locales.some(function(l) { return path.startsWith('/' + l + '/') || path === '/' + l; });
          if (!isOnLocale && locales.indexOf(stored) !== -1) {
            window.location.replace('/' + stored + path);
            return;
          }
        }
        if (stored) return;
        if (/bot|crawl|spider/i.test(navigator.userAgent)) return;
        var langs = navigator.languages || [navigator.language];
        var supported = {zh:1,'zh-Hant':1,es:1,fr:1,de:1,ja:1,ko:1,pt:1,ru:1,ar:1,it:1};
        for (var i = 0; i < langs.length; i++) {
          var l = langs[i].toLowerCase();
          if (supported[l]) { doRedirect(l); return; }
          if (l.indexOf('zh') === 0) {
            if (l.indexOf('tw') !== -1 || l.indexOf('hant') !== -1 || l.indexOf('hk') !== -1 || l.indexOf('mo') !== -1) { doRedirect('zh-Hant'); return; }
            doRedirect('zh'); return;
          }
          if (l.indexOf('pt') === 0) { doRedirect('pt'); return; }
          var prefix = l.split('-')[0];
          if (supported[prefix]) { doRedirect(prefix); return; }
        }
        function doRedirect(lang) {
          localStorage.setItem('picshift_lang', lang);
          var locales = ['zh','zh-Hant','es','fr','de','ja','ko','pt','ru','ar','it'];
          var isOnLocale = locales.some(function(l) { return path.startsWith('/' + l + '/') || path === '/' + l; });
          if (!isOnLocale) {
            window.location.replace('/' + lang + path);
          }
        }
      })();
    </script>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-light-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-light-16x16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" media="(prefers-color-scheme: light)" />
    <!-- Fallback for browsers that ignore media on rel=icon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="baidu-site-verification" content="codeva-cc4KkSkyev" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {ogArticleMeta && <meta name="author" content={ogArticleMeta.author} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternate links -->
    {!noAlternate && SUPPORTED_LOCALES.map((locale) => (
      <link rel="alternate" hreflang={LOCALE_CONFIG[locale].hrefLang} href={buildHrefLangUrl(locale)} />
    ))}
    {!noAlternate && <link rel="alternate" hreflang="x-default" href={buildHrefLangUrl('en' as Locale)} />}

    <meta name="theme-color" content="#1a2332" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="PicShift" />
    <meta property="og:locale" content={OG_LOCALE[lang] || 'en_US'} />
    {SUPPORTED_LOCALES.filter((l) => l !== lang).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l] || 'en_US'} />
    ))}
    {ogArticleMeta && (
      <>
        <meta property="article:published_time" content={ogArticleMeta.publishedTime} />
        <meta property="article:modified_time" content={ogArticleMeta.modifiedTime} />
        <meta property="article:author" content={ogArticleMeta.author} />
        {ogArticleMeta.tags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Structured Data -->
    {orgSchema && <script type="application/ld+json" set:html={orgSchema} />}
    <script type="application/ld+json" set:html={websiteSchema} />

    <!-- Inter font: preload key weights to avoid layout shift -->
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Analytics: Umami (privacy-friendly, no cookies) -->
    {import.meta.env.PROD && <script defer src="https://cloud.umami.is/script.js" data-website-id="5e8e298a-edc6-4bb7-a7cb-04714bffc9c0"></script>}
    <!-- Analytics: Cloudflare Web Analytics -->
    {import.meta.env.PROD && <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "55349de43bae4234983bd69de095874d"}'></script>}

    <!-- PWA: Service Worker registration (production only) -->
    {import.meta.env.PROD && <script is:inline src="/registerSW.js"></script>}
  </head>
  <body class="min-h-screen flex flex-col bg-page-bg text-text-primary font-sans">
    <script is:inline>
      (function() {
        try {
          // Test if browser supports CSS @layer (required by Tailwind CSS v4)
          var s = document.createElement('style');
          s.textContent = '@layer test { }';
          document.head.appendChild(s);
          var supported = s.sheet && s.sheet.cssRules && s.sheet.cssRules.length > 0;
          document.head.removeChild(s);
          if (!supported) throw 0;
        } catch(e) {
          document.body.innerHTML =
            '<div style="background:#1a2332;color:#e8edf5;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;min-height:100vh;padding:24px;text-align:center;">' +
              '<div style="max-width:480px;margin:30vh auto 0;">' +
                '<div style="font-size:48px;margin-bottom:16px;">&#9888;&#65039;</div>' +
                '<h1 style="font-size:22px;font-weight:700;margin-bottom:12px;">Browser Update Required</h1>' +
                '<p style="font-size:15px;line-height:1.6;color:#8fa3be;margin-bottom:24px;">' +
                  'PicShift requires a modern browser to work properly.<br>' +
                  'Please update your system or browser to the latest version.' +
                '</p>' +
                '<p style="font-size:13px;color:#64748b;">' +
                  'iOS 16.4+ · Chrome 111+ · Firefox 128+ · Edge 111+' +
                '</p>' +
              '</div>' +
            '</div>';
        }
      })();
    </script>
    <slot />
  </body>
</html>
