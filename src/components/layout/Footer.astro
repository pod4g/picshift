---
import { getUI, localePath } from '../../i18n';
import { getDocsUi } from '../../i18n/docsUi';
import type { Locale } from '../../i18n/config';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const ui = getUI(lang);
const docsUi = getDocsUi(lang);
const localOnlyLabel = 'Local-only processing';
---

<footer class="bg-drop-bg border-t border-border mt-auto">
  <div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-3">
      <div class="order-2 lg:order-1">
        <p class="text-sm text-text-secondary whitespace-nowrap">
          {ui.copyright}
        </p>
      </div>

      <div class="order-3 lg:order-2 hidden xl:flex items-center gap-1.5 text-sm text-success font-medium whitespace-nowrap">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
          />
        </svg>
        {localOnlyLabel}
      </div>

      <div class="order-1 lg:order-3 flex items-center gap-4 whitespace-nowrap">
        <a
          href="mailto:support@picshift.app"
          class="text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          support@picshift.app
        </a>
        <span class="text-border">|</span>
        <a
          href={localePath('/privacy', lang)}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          {ui.privacyPolicy}
        </a>
        <span class="text-border">|</span>
        <a
          href={localePath('/docs', lang)}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          Docs
        </a>
        <span class="text-border">|</span>
        <a
          href={localePath('/docs/why-picshift', lang)}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          {docsUi.aboutPicShift}
        </a>
      </div>
    </div>
  </div>
</footer>
