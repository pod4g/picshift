---
import { TOOL_PAGES } from '../../data/tools';
import { getUI, localePath, SUPPORTED_LOCALES, LOCALE_CONFIG } from '../../i18n';
import { getPageTranslations } from '../../i18n/translations';
import type { Locale } from '../../i18n/config';

interface Props {
  lang?: Locale;
  pagePath?: string;
}

const { lang = 'en', pagePath = '/' } = Astro.props;
const ui = getUI(lang);
const pageTranslations = getPageTranslations(lang);
const currentNativeName = LOCALE_CONFIG[lang].nativeName;
---

<header class="sticky top-0 z-50 bg-card-bg/95 backdrop-blur-sm border-b border-border">
  <!-- Hidden checkbox for mobile menu state -->
  <input type="checkbox" id="mobile-menu-toggle" class="hidden" aria-label="Toggle menu" />

  <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href={localePath('/', lang)} class="flex items-center gap-2 text-xl font-bold hero-gradient hover:opacity-80 transition-opacity">
      <img src="/android-chrome-192x192.png" alt="PicShift" width="44" height="44" class="rounded-xl" />
      PicShift
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-4">
      <div class="relative group">
        <button
          class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors flex items-center gap-1"
          aria-haspopup="true"
        >
          {ui.allTools}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-1 w-56 bg-card-bg rounded-xl shadow-lg border border-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {TOOL_PAGES.map((tool) => {
            const toolTranslation = pageTranslations.tools[tool.slug];
            const toolLabel = toolTranslation?.h1 || tool.h1;
            return (
              <a
                href={localePath(`/${tool.slug}`, lang)}
                class="block px-4 py-2 text-sm text-text-secondary hover:text-text-primary hover:bg-drop-bg transition-colors"
              >
                {toolLabel}
              </a>
            );
          })}
        </div>
      </div>
      <a
        href={localePath('/privacy', lang)}
        class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors"
      >
        {ui.navPrivacy}
      </a>

      <!-- Language switcher (desktop) -->
      <div class="relative group">
        <button
          class="text-sm font-medium text-text-secondary hover:text-text-primary transition-colors flex items-center gap-1"
          aria-haspopup="true"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          {currentNativeName}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 top-full mt-1 w-48 bg-card-bg rounded-xl shadow-lg border border-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 max-h-80 overflow-y-auto">
          {SUPPORTED_LOCALES.map((locale) => (
            <a
              href={localePath(pagePath, locale)}
              data-lang-switch={locale}
              class={`block px-4 py-2 text-sm transition-colors ${locale === lang ? 'text-primary-500 font-medium bg-primary-500/5' : 'text-text-secondary hover:text-text-primary hover:bg-drop-bg'}`}
            >
              {LOCALE_CONFIG[locale].nativeName}
            </a>
          ))}
        </div>
      </div>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        class="rounded-lg p-2 text-text-secondary hover:text-text-primary hover:bg-drop-bg transition-colors"
        aria-label="Toggle theme"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="theme-icon-sun hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="theme-icon-moon hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>
    </div>

    <!-- Mobile: theme toggle + hamburger -->
    <div class="flex items-center gap-2 md:hidden">
      <button
        id="theme-toggle-mobile"
        type="button"
        class="rounded-lg p-2 text-text-secondary hover:text-text-primary hover:bg-drop-bg transition-colors"
        aria-label="Toggle theme"
      >
        <svg class="theme-icon-sun hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <svg class="theme-icon-moon hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>
      <label
        for="mobile-menu-toggle"
        class="hamburger flex flex-col gap-1.5 cursor-pointer p-1"
        aria-label="Open menu"
      >
        <span class="block w-6 h-0.5 bg-text-primary rounded transition-transform"></span>
        <span class="block w-6 h-0.5 bg-text-primary rounded transition-opacity"></span>
        <span class="block w-6 h-0.5 bg-text-primary rounded transition-transform"></span>
      </label>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div class="mobile-nav max-h-0 overflow-hidden transition-all duration-300 md:hidden">
    <div class="px-4 pb-4 space-y-1 border-t border-border pt-3">
      <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide mb-2">{ui.allTools}</p>
      {TOOL_PAGES.map((tool) => {
        const toolTranslation = pageTranslations.tools[tool.slug];
        const toolLabel = toolTranslation?.h1 || tool.h1;
        return (
          <a
            href={localePath(`/${tool.slug}`, lang)}
            class="block py-2 px-3 text-sm text-text-secondary hover:text-text-primary hover:bg-drop-bg rounded-lg transition-colors"
          >
            {toolLabel}
          </a>
        );
      })}
      <hr class="border-border my-2" />
      <a
        href={localePath('/privacy', lang)}
        class="block py-2 px-3 text-sm text-text-secondary hover:text-text-primary hover:bg-drop-bg rounded-lg transition-colors"
      >
        {ui.privacyPolicy}
      </a>
      <hr class="border-border my-2" />
      <!-- Language switcher (mobile) -->
      <p class="text-xs font-semibold text-text-secondary uppercase tracking-wide mb-2">{currentNativeName}</p>
      <div class="grid grid-cols-2 gap-1">
        {SUPPORTED_LOCALES.map((locale) => (
          <a
            href={localePath(pagePath, locale)}
            data-lang-switch={locale}
            class={`block py-2 px-3 text-sm rounded-lg transition-colors ${locale === lang ? 'text-primary-500 font-medium bg-primary-500/5' : 'text-text-secondary hover:text-text-primary hover:bg-drop-bg'}`}
          >
            {LOCALE_CONFIG[locale].nativeName}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  /* Mobile menu: show when checkbox is checked */
  #mobile-menu-toggle:checked ~ .mobile-nav {
    max-height: 600px;
  }

  /* Hamburger animation when checked */
  #mobile-menu-toggle:checked ~ nav .hamburger span:first-child {
    transform: rotate(45deg) translate(3px, 5px);
  }
  #mobile-menu-toggle:checked ~ nav .hamburger span:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-toggle:checked ~ nav .hamburger span:last-child {
    transform: rotate(-45deg) translate(3px, -5px);
  }
</style>

<script is:inline>
  (function() {
    function updateIcons() {
      var isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.theme-icon-sun').forEach(function(el) {
        el.style.display = isDark ? 'block' : 'none';
      });
      document.querySelectorAll('.theme-icon-moon').forEach(function(el) {
        el.style.display = isDark ? 'none' : 'block';
      });
    }

    function toggle() {
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('picshift_theme', isDark ? 'dark' : 'light');
      updateIcons();
    }

    document.getElementById('theme-toggle')?.addEventListener('click', toggle);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggle);

    updateIcons();

    // Language switcher: store preference on click
    document.querySelectorAll('[data-lang-switch]').forEach(function(el) {
      el.addEventListener('click', function() {
        localStorage.setItem('picshift_lang', el.getAttribute('data-lang-switch'));
      });
    });
  })();
</script>
