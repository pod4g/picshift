---
// Temporary test page — delete after benchmarking
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WASM Encoder Benchmark</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, system-ui, sans-serif; background: #0f0f0f; color: #e0e0e0; padding: 24px; }
  h1 { font-size: 20px; margin-bottom: 16px; }
  .drop-zone {
    border: 2px dashed #444; border-radius: 12px; padding: 40px; text-align: center;
    cursor: pointer; margin-bottom: 24px; transition: border-color .2s;
  }
  .drop-zone:hover, .drop-zone.dragover { border-color: #6366f1; }
  .drop-zone input { display: none; }
  .controls { margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
  #status { margin-bottom: 16px; font-size: 14px; color: #999; min-height: 20px; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th, td { padding: 10px 12px; text-align: left; border-bottom: 1px solid #222; }
  th { color: #999; font-weight: 600; font-size: 12px; text-transform: uppercase; }
  .better { color: #10b981; font-weight: 600; }
  .worse { color: #f59e0b; }
  .tag { font-size: 11px; color: #888; margin-left: 4px; }
  .section { margin-top: 32px; }
  .section h2 { font-size: 16px; margin-bottom: 12px; color: #a0a0a0; }
  .spin { display: inline-block; width: 12px; height: 12px; border: 2px solid #6366f1; border-top-color: transparent; border-radius: 50%; animation: spin .6s linear infinite; margin-right: 4px; vertical-align: middle; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>
<h1>Browser Native vs WASM Encoder</h1>

<div class="drop-zone" id="dropZone">
  <p>Drop images here or click to select</p>
  <input type="file" id="fileInput" accept=".jpg,.jpeg,.png,.webp" multiple>
</div>

<div class="controls">
  <label>Quality:</label>
  <input type="range" id="quality" min="1" max="100" value="85" style="width:200px">
  <span id="qLabel">85%</span>
</div>

<div id="status"></div>

<div class="section" id="resultsSection" style="display:none">
  <h2>Results</h2>
  <table>
    <thead>
      <tr>
        <th>File</th>
        <th>Original</th>
        <th>Format</th>
        <th>Browser Native</th>
        <th>WASM</th>
        <th>Diff</th>
      </tr>
    </thead>
    <tbody id="tbody"></tbody>
  </table>
</div>

<script>
  import { init as initJpeg } from '@jsquash/jpeg/encode.js';
  import encodeMozJpeg from '@jsquash/jpeg/encode.js';
  import { init as initOxipng } from '@jsquash/oxipng/optimise.js';
  import optimisePng from '@jsquash/oxipng/optimise.js';
  import { init as initWebp } from '@jsquash/webp/encode.js';
  import encodeWebP from '@jsquash/webp/encode.js';

  // Inline SIMD detection (same logic as wasm-feature-detect)
  function detectSIMD() {
    try {
      return WebAssembly.validate(new Uint8Array([0,97,115,109,1,0,0,0,1,5,1,96,0,1,123,3,2,1,0,10,10,1,8,0,65,0,253,15,253,98,11]));
    } catch { return false; }
  }

  // Pre-init WASM modules from public directory
  async function initAll() {
    // JPEG (emscripten) — pass compiled WebAssembly.Module
    const jpegWasm = await WebAssembly.compileStreaming(fetch('/wasm/mozjpeg_enc.wasm'));
    await initJpeg(jpegWasm);

    // OxiPNG (wasm-bindgen) — pass URL to fetch from
    await initOxipng('/wasm/squoosh_oxipng_bg.wasm');

    // WebP (emscripten + SIMD) — compile the matching wasm
    const hasSIMD = detectSIMD();
    const webpUrl = hasSIMD ? '/wasm/webp_enc_simd.wasm' : '/wasm/webp_enc.wasm';
    const webpWasm = await WebAssembly.compileStreaming(fetch(webpUrl));
    await initWebp(webpWasm);
  }

  let wasmReady = initAll();

  const dropZone = document.getElementById('dropZone');
  const fileInput = document.getElementById('fileInput');
  const statusEl = document.getElementById('status');
  const resultsSection = document.getElementById('resultsSection');
  const tbody = document.getElementById('tbody');
  const qualitySlider = document.getElementById('quality');
  const qLabel = document.getElementById('qLabel');

  statusEl.innerHTML = '<span class="spin"></span> Loading WASM modules...';
  wasmReady.then(() => { statusEl.textContent = 'Ready. Drop images to start.'; })
    .catch(err => { statusEl.textContent = 'WASM init error: ' + err.message; });

  qualitySlider.addEventListener('input', () => { qLabel.textContent = qualitySlider.value + '%'; });

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('dragover'); run(Array.from(e.dataTransfer.files)); });
  fileInput.addEventListener('change', () => run(Array.from(fileInput.files)));

  function fmt(bytes) {
    if (bytes === 0) return '0 B';
    const k = 1024, s = ['B','KB','MB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + s[i];
  }

  async function getImageData(file) {
    const bmp = await createImageBitmap(file);
    const c = new OffscreenCanvas(bmp.width, bmp.height);
    const ctx = c.getContext('2d');
    ctx.drawImage(bmp, 0, 0);
    bmp.close();
    return { imageData: ctx.getImageData(0, 0, c.width, c.height), canvas: c };
  }

  async function run(files) {
    await wasmReady;
    const q = Number(qualitySlider.value);
    tbody.innerHTML = '';
    resultsSection.style.display = 'block';

    for (const file of files) {
      statusEl.innerHTML = '<span class="spin"></span> Processing: ' + file.name;

      try {
        const { imageData, canvas } = await getImageData(file);

        const tests = [
          {
            format: 'JPEG',
            native: () => canvas.convertToBlob({ type: 'image/jpeg', quality: q / 100 }),
            wasm: () => encodeMozJpeg(imageData, { quality: q }),
            label: 'MozJPEG',
          },
          {
            format: 'PNG',
            native: () => canvas.convertToBlob({ type: 'image/png' }),
            wasm: async () => {
              const png = await canvas.convertToBlob({ type: 'image/png' });
              const buf = await png.arrayBuffer();
              return optimisePng(buf, { level: 3 });
            },
            label: 'OxiPNG',
          },
          {
            format: 'WebP',
            native: () => canvas.convertToBlob({ type: 'image/webp', quality: q / 100 }),
            wasm: () => encodeWebP(imageData, { quality: q }),
            label: 'libwebp',
          },
        ];

        for (const t of tests) {
          const row = tbody.insertRow();
          row.innerHTML = `<td>${file.name}</td><td>${fmt(file.size)}</td><td>${t.format}</td><td><span class="spin"></span></td><td><span class="spin"></span></td><td>—</td>`;

          try {
            const t0 = performance.now();
            const nBlob = await t.native();
            const nTime = (performance.now() - t0).toFixed(0);

            const t1 = performance.now();
            const wResult = await t.wasm();
            const wTime = (performance.now() - t1).toFixed(0);

            const nSize = nBlob.size;
            const wSize = wResult instanceof Blob ? wResult.size
              : wResult instanceof ArrayBuffer ? wResult.byteLength
              : wResult.byteLength ?? 0;

            const diff = ((1 - wSize / nSize) * 100).toFixed(1);
            const better = wSize < nSize;

            row.cells[3].textContent = fmt(nSize) + ' (' + nTime + 'ms)';
            row.cells[4].innerHTML = fmt(wSize) + ' (' + wTime + 'ms) <span class="tag">[' + t.label + ']</span>';
            row.cells[5].innerHTML = better
              ? '<span class="better">-' + Math.abs(diff) + '%</span>'
              : '<span class="worse">+' + Math.abs(diff) + '%</span>';
          } catch (err) {
            row.cells[3].textContent = '—';
            row.cells[4].textContent = err.message;
            row.cells[5].textContent = '—';
          }
        }
      } catch (err) {
        statusEl.textContent = 'Error: ' + err.message;
      }
    }
    statusEl.textContent = 'Done.';
  }
</script>
</body>
</html>
