---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import RelatedTools from '../../components/blog/RelatedTools.astro';
import { TOOL_PAGES } from '../../data/tools';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const { title, description, cover, publishedAt, updatedAt, author, tags, relatedTools } = post.data;

// 博客页统一使用无尾斜杠规范 URL，和全站 canonical 策略保持一致
const canonical = `https://picshift.app/blog/${post.slug}`;
const pagePath = `/blog/${post.slug}`;
const toolPaths = TOOL_PAGES.map((tool) => `/${tool.slug}`);
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(wordCount / 230));
const dateStr = publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedAt?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  url: canonical,
  inLanguage: 'en',
  image: cover ? `https://picshift.app${cover}` : undefined,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@type': 'Organization', name: author, url: 'https://picshift.app' },
  publisher: { '@type': 'Organization', name: 'PicShift', url: 'https://picshift.app' },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
});
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://picshift.app' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://picshift.app/blog' },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
});

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const currentIdx = allPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIdx < allPosts.length - 1 ? allPosts[currentIdx + 1] : null;
const nextPost = currentIdx > 0 ? allPosts[currentIdx - 1] : null;
---

<Layout
  title={`${title} | PicShift Blog`}
  description={description}
  canonical={canonical}
  lang="en"
  pagePath={pagePath}
  ogType="article"
  ogImage={cover}
  noAlternate
  ogArticleMeta={{
    publishedTime: publishedAt.toISOString(),
    modifiedTime: (updatedAt ?? publishedAt).toISOString(),
    author: author,
    tags: tags ?? [],
  }}
>
  <Header lang="en" pagePath={pagePath} languageSwitchMode="locale-home" />

  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
      <div class="flex items-start gap-0 xl:gap-4">
        <!-- Article -->
        <article class="min-w-0 flex-1 max-w-[680px] mx-auto xl:mx-0">
          <!-- Breadcrumb -->
          <nav aria-label="Breadcrumb" class="mb-6 text-sm text-text-secondary font-sans">
            <a href="/" class="hover:text-text-primary hover:underline">Home</a>
            <span class="mx-2">/</span>
            <a href="/blog" class="hover:text-text-primary hover:underline">Blog</a>
            <span class="mx-2">/</span>
            <span class="text-text-primary">{title}</span>
          </nav>

          <!-- Header -->
          <header class="mb-10">
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {tags.map((tag) => (
                  <span class="text-xs font-medium text-primary-500 bg-primary-500/10 rounded-full px-3 py-1">
                    {tag}
                  </span>
                ))}
              </div>
            )}
            <h1 class="text-3xl sm:text-4xl md:text-[2.625rem] font-bold leading-tight text-text-primary font-sans mb-4">
              {title}
            </h1>
            <p class="text-lg text-text-secondary font-serif leading-relaxed mb-5">
              {description}
            </p>
            <div class="flex items-center gap-3 text-sm text-text-secondary font-sans">
              <time datetime={publishedAt.toISOString()}>{dateStr}</time>
              <span class="text-border">·</span>
              <span>{readingTime} min read</span>
              {updatedStr && updatedStr !== dateStr && (
                <>
                  <span class="text-border">·</span>
                  <span>Updated {updatedStr}</span>
                </>
              )}
            </div>
          </header>

          <!-- Prose content -->
          <div class="blog-prose">
            <Content />
          </div>

          <!-- Related tools -->
          <RelatedTools slugs={relatedTools} />

          <!-- Prev / Next -->
          {(prevPost || nextPost) && (
            <nav class="mt-12 pt-8 border-t border-border flex justify-between gap-4 font-sans">
              {prevPost ? (
                <a href={`/blog/${prevPost.slug}`} class="group flex-1 min-w-0">
                  <span class="text-xs text-text-secondary uppercase tracking-wider">Previous</span>
                  <p class="text-sm font-medium text-text-primary group-hover:text-primary-500 transition-colors truncate mt-1">
                    {prevPost.data.title}
                  </p>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/blog/${nextPost.slug}`} class="group flex-1 min-w-0 text-right">
                  <span class="text-xs text-text-secondary uppercase tracking-wider">Next</span>
                  <p class="text-sm font-medium text-text-primary group-hover:text-primary-500 transition-colors truncate mt-1">
                    {nextPost.data.title}
                  </p>
                </a>
              ) : <div />}
            </nav>
          )}
        </article>

        <!-- TOC sidebar -->
        <TableOfContents headings={headings} />
      </div>
    </div>

    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </main>

  <Footer lang="en" />

  <script is:inline define:vars={{ slug: post.slug, toolPaths }}>
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href^="/"]');
      if (!link) return;
      var to = link.getAttribute('href');
      if (to && toolPaths.includes(to.replace(/\/$/, ''))) {
        try {
          var ts = Math.floor(Date.now() / 1000);
          window.umami?.track(function (props) {
            return Object.assign({}, props, {
              name: 'blog_link_click',
              timestamp: ts,
              data: { from: '/blog/' + slug, to: to },
            });
          });
        } catch {}
      }
    });
  </script>
</Layout>

<style is:global>
  .blog-prose {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-text-primary);
  }

  /* Stronger contrast in light mode for long-form reading */
  :root:not(.dark) .blog-prose {
    color: #1a1a1a;
  }

  .blog-prose p {
    margin-bottom: 1.75em;
  }

  .blog-prose h2 {
    font-family: var(--font-sans);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--color-text-primary);
    scroll-margin-top: 5rem;
  }

  .blog-prose h3 {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.4;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
    scroll-margin-top: 5rem;
  }

  .blog-prose a {
    color: var(--color-primary-500);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
    transition: color 0.15s;
  }
  .blog-prose a:hover {
    color: var(--color-secondary-500);
  }

  .blog-prose strong {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .blog-prose em {
    font-style: italic;
  }

  .blog-prose blockquote {
    border-left: 3px solid var(--color-primary-500);
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }
  .blog-prose blockquote p {
    margin-bottom: 0.75em;
  }

  .blog-prose ul,
  .blog-prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.75em;
  }
  .blog-prose li {
    margin-bottom: 0.5em;
  }
  .blog-prose ul {
    list-style: disc;
  }
  .blog-prose ol {
    list-style: decimal;
  }

  .blog-prose code {
    font-size: 0.9em;
    background: var(--color-drop-bg);
    border-radius: 4px;
    padding: 0.15em 0.4em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .blog-prose pre {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    margin: 2rem 0;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .blog-prose pre code {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: inherit;
  }

  .blog-prose img {
    border-radius: 0.5rem;
    margin: 2rem 0;
    max-width: 100%;
    height: auto;
  }

  .blog-prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .blog-prose table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 2rem 0;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .blog-prose th,
  .blog-prose td {
    padding: 0.875rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }
  .blog-prose th {
    background: var(--color-drop-bg);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-secondary);
  }
  .blog-prose tbody tr:last-child td {
    border-bottom: none;
  }
  .blog-prose tbody tr:hover {
    background: var(--color-drop-bg);
  }
</style>
