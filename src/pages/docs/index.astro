---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { CONTENT_DATE_MODIFIED, DOCS_DATE_PUBLISHED } from '../../lib/contentDates';

const lang = 'en' as const;
const title = 'PicShift Docs and Guides';
const description = 'Guides for privacy, format compatibility, and image quality optimization in PicShift.';
const canonical = 'https://picshift.app/docs';
const pagePath = '/docs';
const datePublished = DOCS_DATE_PUBLISHED;
const dateModified = CONTENT_DATE_MODIFIED;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: canonical,
  inLanguage: 'en',
  datePublished,
  dateModified,
  publisher: { '@type': 'Organization', name: 'PicShift', url: 'https://picshift.app' },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://picshift.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Docs',
      item: canonical,
    },
  ],
};

const docs = [
  {
    href: '/docs/privacy-local-processing',
    title: 'Privacy and Local Processing',
    description: 'How PicShift keeps image processing on-device and what data is or is not used.',
  },
  {
    href: '/docs/format-compatibility',
    title: 'Format Compatibility Guide',
    description: 'A practical compatibility matrix for JPG, PNG, WebP, HEIC/HEIF, and AVIF.',
  },
  {
    href: '/docs/image-quality-vs-file-size',
    title: 'Image Quality vs File Size',
    description: 'How to pick quality settings for the best trade-off between visual clarity and size.',
  },
  {
    href: '/docs/size-increase-explainer',
    title: 'Why Output Size Can Increase',
    description: 'How PicShift estimates deep compression and computes B/pixel in size-increase explanations.',
  },
  {
    href: '/docs/why-picshift',
    title: 'Why I Built PicShift',
    description: 'Why PicShift exists: local-only processing, privacy constraints, multi-format comparison workflow, and continuous iteration.',
  },
];
const docsItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'PicShift documentation guides',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: docs.length,
  itemListElement: docs.map((doc, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: doc.title,
    url: `https://picshift.app${doc.href}`,
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />

  <main class="flex-1">
    <section class="max-w-4xl mx-auto px-4 py-10 sm:py-14">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-text-secondary">
        <a href="/" class="hover:text-text-primary hover:underline">Home</a>
        <span class="mx-2">/</span>
        <span class="text-text-primary">Docs</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">PicShift Docs and Guides</h1>
      <p class="text-base sm:text-lg text-text-secondary mb-8">
        Explore practical guides for private image processing, format decisions, and compression quality.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {docs.map((doc) => (
          <a
            href={doc.href}
            class="block rounded-xl border border-border bg-card-bg p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
          >
            <h2 class="text-lg font-semibold text-text-primary mb-2">{doc.title}</h2>
            <p class="text-sm text-text-secondary">{doc.description}</p>
          </a>
        ))}
      </div>
      <p class="text-sm text-text-secondary pt-4 border-t border-border mt-6">Last updated: {dateModified}</p>
    </section>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(docsItemListSchema)} />
  </main>

  <Footer lang={lang} />
</Layout>
