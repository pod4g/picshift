const content = localized[lang];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `https://picshift.app/${lang}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: content.h1,
      item: canonical,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout title={content.title} description={content.description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text-primary mb-4">
        {content.h1}
      </h1>
      <p class="text-text-secondary text-base sm:text-lg mb-6">{content.lead}</p>

      <section class="mb-6 bg-card-bg border border-border rounded-xl p-4 sm:p-5">
        <h2 class="text-xl font-semibold text-text-primary mb-2">{content.alternativesTitle}</h2>
        <ul class="list-disc list-inside text-text-secondary space-y-1">
          <li><a class="text-primary-500 hover:underline" href={`/${lang}/image-compressor`}>Image Compressor</a> — {content.alternatives[0]}</li>
          <li><a class="text-primary-500 hover:underline" href={`/${lang}/jpg-to-webp`}>JPG to WebP</a> — {content.alternatives[1]}</li>
          <li><a class="text-primary-500 hover:underline" href={`/${lang}/png-to-jpg`}>PNG to JPG</a> — {content.alternatives[2]}</li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-text-primary">{content.faqTitle}</h2>
        {content.faq.map((item) => (
          <article class="bg-card-bg border border-border rounded-xl p-4 sm:p-5">
            <h3 class="font-semibold text-text-primary mb-2">{item.q}</h3>
            <p class="text-text-secondary">{item.a}</p>
          </article>
        ))}
      </section>

      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
