---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PrivacyBadge from '../../components/seo/PrivacyBadge.astro';
import Converter from '../../components/converter/Converter';
import { TOOL_PAGES } from '../../data/tools';
import { getUI, localePath, SUPPORTED_LOCALES } from '../../i18n';
import { getPageTranslations } from '../../i18n/translations';
import type { Locale } from '../../i18n/config';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== 'en')
    .map((l) => ({
      params: { lang: l },
      props: { lang: l },
    }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const ui = getUI(lang);
const pageTranslations = getPageTranslations(lang);
const title = pageTranslations.home.title;
const description = pageTranslations.home.description;
---

<Layout title={title} description={description} lang={lang} pagePath="/">
  <Header lang={lang} pagePath="/" />

  <main class="flex-1">
    <!-- Hero + Converter -->
    <section class="pt-8 sm:pt-12 md:pt-16 pb-8 sm:pb-12 px-4">
      <div class="max-w-3xl mx-auto text-center mb-6 sm:mb-8">
        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-3 sm:mb-4">
          <span class="hero-gradient">{ui.heroTitle1}</span>
          <br />
          <span class="hero-gradient">{ui.heroTitle2}</span>
        </h1>
        <p class="relative text-sm sm:text-base md:text-lg text-text-secondary w-fit mx-auto mb-4 px-4 sm:px-8">
          <svg class="hidden md:block absolute -left-1 -top-[10px] w-4 h-4 text-primary-500/70" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16l-6.4 5.2L8 14 2 9.2h7.6L12 2z"/></svg>
          <svg class="hidden md:block absolute left-2 top-0.5 w-3 h-3 text-secondary-500/60" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16l-6.4 5.2L8 14 2 9.2h7.6L12 2z"/></svg>
          {ui.heroSubtitle}
          <svg class="hidden md:block absolute -right-1 -bottom-[10px] w-3.5 h-3.5 text-primary-500/70" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16l-6.4 5.2L8 14 2 9.2h7.6L12 2z"/></svg>
          <svg class="hidden md:block absolute right-2 -bottom-0.5 w-2.5 h-2.5 text-secondary-500/60" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16l-6.4 5.2L8 14 2 9.2h7.6L12 2z"/></svg>
        </p>
        <div class="flex justify-center">
          <PrivacyBadge lang={lang} />
        </div>
      </div>

      <div class="max-w-3xl mx-auto">
        <!-- Skeleton: visible until React mounts, prevents layout shift -->
        <div id="converter-skeleton" class="rounded-xl border border-border bg-card-bg p-4 sm:p-6 shadow-sm">
          <div class="mb-4 sm:mb-6 flex flex-wrap items-center gap-3 sm:gap-4">
            <div class="flex items-center gap-2">
              <span class="text-xs sm:text-sm font-semibold text-text-secondary uppercase tracking-wide whitespace-nowrap">{ui.outputLabel}</span>
              <div class="flex rounded-lg border border-primary-500/30 bg-primary-500/10 p-0.5">
                <button type="button" disabled data-skel-fmt="jpg" class="rounded-md px-2.5 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-bold transition-all duration-150 disabled:cursor-not-allowed bg-primary-500 text-white shadow-sm">JPG</button>
                <button type="button" disabled data-skel-fmt="png" class="rounded-md px-2.5 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-bold transition-all duration-150 disabled:cursor-not-allowed text-primary-500">PNG</button>
                <button type="button" disabled data-skel-fmt="webp" class="rounded-md px-2.5 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-bold transition-all duration-150 disabled:cursor-not-allowed text-primary-500">WebP</button>
                <button type="button" disabled data-skel-fmt="avif" class="rounded-md px-2.5 py-1 sm:px-4 sm:py-1.5 text-xs sm:text-sm font-bold transition-all duration-150 disabled:cursor-not-allowed text-primary-500">AVIF</button>
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium text-text-primary">{ui.qualityLabel}</label>
                <span id="skel-quality-val" class="text-sm font-medium text-primary-500">85%</span>
              </div>
              <input type="range" min="1" max="100" value="85" disabled class="h-2 w-full cursor-not-allowed appearance-none rounded-full bg-border opacity-50 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-primary-500 [&::-webkit-slider-thumb]:shadow-sm [&::-moz-range-thumb]:h-4 [&::-moz-range-thumb]:w-4 [&::-moz-range-thumb]:rounded-full [&::-moz-range-thumb]:border-0 [&::-moz-range-thumb]:bg-primary-500 [&::-moz-range-thumb]:shadow-sm" />
            </div>
          </div>
          <div class="flex min-h-[160px] sm:min-h-[200px] flex-col items-center justify-center rounded-xl border-2 border-dashed border-border bg-drop-bg p-5 sm:p-8">
            <svg class="mb-3 sm:mb-4 h-10 w-10 sm:h-12 sm:w-12 text-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" /></svg>
            <p class="text-base font-medium text-text-primary">{ui.dropDrag}</p>
            <p class="mt-1 text-sm text-text-secondary">{ui.dropClick}</p>
            <p class="mt-3 text-xs text-text-secondary">{ui.dropFormats}</p>
          </div>
        </div>
        <script is:inline>
          (function() {
            try {
              var raw = localStorage.getItem('picshift_prefs');
              if (!raw) return;
              var prefs = JSON.parse(raw);
              var fmt = prefs.outputFormat;
              var q = prefs.quality;
              if (fmt) {
                var btns = document.querySelectorAll('#converter-skeleton [data-skel-fmt]');
                btns.forEach(function(btn) {
                  if (btn.getAttribute('data-skel-fmt') === fmt) {
                    btn.className = btn.className.replace('text-primary-500', 'bg-primary-500 text-white shadow-sm');
                  } else {
                    btn.className = btn.className.replace('bg-primary-500 text-white shadow-sm', 'text-primary-500');
                  }
                });
              }
              if (q != null) {
                var valEl = document.getElementById('skel-quality-val');
                if (valEl) valEl.textContent = q + '%';
                var slider = document.querySelector('#converter-skeleton input[type=range]');
                if (slider) slider.value = q;
              }
            } catch(e) {}
          })();
        </script>
        <Converter client:only="react" fullPage lang={lang} />
      </div>
    </section>

    <!-- Tool Cards Grid -->
    <section class="pb-10 sm:pb-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-xl sm:text-2xl font-bold text-text-primary text-center mb-6 sm:mb-8">
          {ui.allConverters}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {TOOL_PAGES.map((tool) => {
            const toolTranslation = pageTranslations.tools[tool.slug];
            const h1Text = toolTranslation?.h1 || tool.h1;
            const introText = toolTranslation?.introText || tool.introText;
            const isCompressor = tool.slug === 'image-compressor';
            const label = isCompressor ? ui.compressImages : h1Text.replace('Convert ', '').replace('Compress ', '');
            const fromTo = isCompressor
              ? 'JPG / PNG / WebP'
              : `${tool.defaultInputFormat?.toUpperCase()} → ${tool.defaultOutputFormat?.toUpperCase()}`;

            return (
              <a
                href={localePath('/' + tool.slug, lang)}
                data-umami-event="tool_card_click"
                data-umami-event-slug={tool.slug}
                class="group block bg-card-bg rounded-xl border border-border p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200"
              >
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                    {isCompressor ? (
                      <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                      </svg>
                    ) : (
                      <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    )}
                  </div>
                  <span class="text-xs font-semibold tracking-wide text-primary-500 uppercase">
                    {fromTo}
                  </span>
                </div>
                <h3 class="font-semibold text-text-primary group-hover:text-primary-600 transition-colors mb-1">
                  {label}
                </h3>
                <p class="text-sm text-text-secondary line-clamp-2">
                  {introText}
                </p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="pb-12 sm:pb-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-xl sm:text-2xl font-bold text-text-primary text-center mb-6 sm:mb-8">
          {ui.comparisonTitle}
        </h2>
        <div class="overflow-x-auto rounded-xl border border-border bg-card-bg shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left py-3 px-4 font-medium text-text-secondary"></th>
                <th class="py-3 px-3 font-bold text-primary-500 text-center">{ui.compColPicShift}</th>
                <th class="py-3 px-3 font-medium text-text-secondary text-center">{ui.compColUpload}</th>
                <th class="py-3 px-3 font-medium text-text-secondary text-center">{ui.compColSingle}</th>
                <th class="py-3 px-3 font-medium text-text-secondary text-center">{ui.compColDesktop}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {[
                [ui.compRowNoUpload, true, false, true, true],
                [ui.compRowHeic, true, false, true, true],
                [ui.compRowBatch, true, true, false, true],
                [ui.compRowCompare, true, false, true, false],
                [ui.compRowOffline, true, false, true, true],
                [ui.compRowNoInstall, true, true, true, false],
                [ui.compRowFree, true, false, true, true],
                [ui.compRowZeroTrace, true, false, true, true],
              ].map(([label, ps, upload, single, desktop]) => (
                <tr class="hover:bg-drop-bg/50 transition-colors">
                  <td class="py-3 px-4 font-medium text-text-primary whitespace-nowrap">{label}</td>
                  <td class="py-3 px-3 text-center">
                    {ps
                      ? <span class="text-success text-lg">&#10003;</span>
                      : <span class="text-error text-lg">&#10007;</span>}
                  </td>
                  <td class="py-3 px-3 text-center">
                    {upload
                      ? <span class="text-success text-lg">&#10003;</span>
                      : <span class="text-error text-lg">&#10007;</span>}
                  </td>
                  <td class="py-3 px-3 text-center">
                    {single
                      ? <span class="text-success text-lg">&#10003;</span>
                      : <span class="text-error text-lg">&#10007;</span>}
                  </td>
                  <td class="py-3 px-3 text-center">
                    {desktop
                      ? <span class="text-success text-lg">&#10003;</span>
                      : <span class="text-error text-lg">&#10007;</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="pb-12 sm:pb-20 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="sr-only">Features</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
          <div class="text-center p-4 sm:p-6">
            <div class="w-12 h-12 rounded-xl bg-primary-500/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text-primary mb-2">{ui.instantTitle}</h3>
            <p class="text-sm text-text-secondary">
              {ui.instantDesc}
            </p>
          </div>
          <div class="text-center p-4 sm:p-6">
            <div class="w-12 h-12 rounded-xl bg-success/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text-primary mb-2">{ui.privateTitle}</h3>
            <p class="text-sm text-text-secondary">
              {ui.privateDesc}
            </p>
          </div>
          <div class="text-center p-4 sm:p-6">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-semibold text-text-primary mb-2">{ui.freeTitle}</h3>
            <p class="text-sm text-text-secondary">
              {ui.freeDesc}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Showcase -->
    <section class="pb-12 sm:pb-20 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-xl sm:text-2xl font-bold text-text-primary text-center mb-2">
          {ui.techSectionTitle}
        </h2>
        <p class="text-sm text-text-secondary text-center mb-6 sm:mb-8">
          {ui.techSectionSubtitle}
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- MozJPEG -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techMozjpegTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techMozjpegDesc}</p>
          </div>
          <!-- OxiPNG -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techOxipngTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techOxipngDesc}</p>
          </div>
          <!-- imagequant -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techImagequantTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techImagequantDesc}</p>
          </div>
          <!-- libwebp SIMD -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-secondary-500/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-secondary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techWebpTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techWebpDesc}</p>
          </div>
          <!-- AVIF Encoder -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-primary-500/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techAvifTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techAvifDesc}</p>
          </div>
          <!-- Worker Pool -->
          <div class="bg-card-bg rounded-xl border border-border p-5 shadow-sm">
            <div class="flex items-center gap-3 mb-2">
              <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              </div>
              <h3 class="font-semibold text-text-primary">{ui.techWorkerPoolTitle}</h3>
            </div>
            <p class="text-sm text-text-secondary">{ui.techWorkerPoolDesc}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</Layout>
