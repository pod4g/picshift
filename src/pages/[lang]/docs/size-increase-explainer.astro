const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  url: canonical,
  inLanguage: lang,
  datePublished,
  dateModified,
  author: { '@type': 'Organization', name: 'PicShift' },
  publisher: { '@type': 'Organization', name: 'PicShift', url: 'https://picshift.app' },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: docsUi.home,
      item: htmlCanonicalUrl(`https://picshift.app/${lang}`),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: docsUi.docs,
      item: docsHubUrl,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonical,
    },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pageContent.faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />

  <main class="flex-1">
    <article class="max-w-3xl mx-auto px-4 py-10 sm:py-14">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-text-secondary">
        <a href={localePath('/', lang)} class="hover:text-text-primary hover:underline">{docsUi.home}</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/docs`} class="hover:text-text-primary hover:underline">{docsUi.docs}</a>
        <span class="mx-2">/</span>
        <span class="text-text-primary">{docsUi.sizeIncreaseDocTitle}</span>
      </nav>

      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">{title}</h1>
      <p class="text-base sm:text-lg text-text-secondary mb-8">{pageContent.intro}</p>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{pageContent.methodTitle}</h2>
        <p class="text-text-secondary mb-3">{pageContent.methodIntro}</p>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {pageContent.methodItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{pageContent.formulaTitle}</h2>
        <div class="rounded-xl border border-border bg-card-bg p-4 sm:p-5">
          <p class="text-text-primary font-medium">{pageContent.formula}</p>
          <p class="text-sm text-text-secondary mt-2">{pageContent.formulaExample}</p>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{pageContent.reasonTitle}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {pageContent.reasonItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{pageContent.boundaryTitle}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {pageContent.boundaryItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.faq}</h2>
        <div class="space-y-4">
          {pageContent.faqs.map((faq) => (
            <div class="rounded-xl border border-border bg-card-bg p-4">
              <h3 class="text-base font-semibold text-text-primary mb-1">{faq.q}</h3>
              <p class="text-sm text-text-secondary">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.relatedPages}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          <li><a href={`/${lang}/docs/image-quality-vs-file-size`} class="text-primary-500 hover:underline">{docsUi.qualityDocTitle}</a></li>
          <li><a href={`/${lang}/docs/format-compatibility`} class="text-primary-500 hover:underline">{docsUi.formatDocTitle}</a></li>
          <li><a href={`/${lang}/docs`} class="text-primary-500 hover:underline">{docsUi.allDocs}</a></li>
        </ul>
      </section>

      <p class="text-sm text-text-secondary pt-4 border-t border-border">{docsUi.lastUpdated}: {dateModified}</p>
    </article>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </main>

  <Footer lang={lang} />
</Layout>
