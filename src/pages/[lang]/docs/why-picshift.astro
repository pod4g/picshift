import type { Locale } from '../../../i18n/config';
import { htmlCanonicalUrl } from '../../../lib/htmlCanonicalUrl';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== 'en')
    .map((l) => ({
      params: { lang: l },
      props: { lang: l },
    }));
}

interface Props {
  lang: Locale;
}

