      ['HEIC / HEIF', 'Foto mobile, efficienza di archiviazione', 'Limitato da sorgente/codec', 'Alta efficienza (output camera standard in genere lossy)'],
      ['AVIF', 'Immagini web ad alta compressione', 'Sì', 'Lossy / Lossless'],
    ],
    quickRecommendations: 'Consigli rapidi',
    recommendations: [
      'Scegli JPG per ampia compatibilità e file più piccoli nelle foto.',
      'Scegli PNG quando servono testo nitido o sfondi trasparenti.',
      'Scegli WebP o AVIF per migliore compressione web quando i browser target li supportano.',
      'Usa il cursore qualità per bilanciare dimensione file e dettaglio visibile.',
    ],
    commonConversionPaths: 'Percorsi di conversione comuni',
    conversionPaths: [
      'HEIC in JPG: condivisione più semplice su app e siti legacy.',
      'PNG in JPG: riduce la dimensione per contenuti fotografici.',
      'JPG in WebP: riduce il peso web a qualità visiva equivalente.',
      'WebP in HEIF: workflow di compatibilità per specifici ecosistemi mobili.',
    ],
  },
}[lang] ?? {
  intro:
    'This page lists practical compatibility facts for common image formats in PicShift. Use it as a quick reference when choosing output format for web publishing, sharing, or archive use.',
  supportedFormats: 'Supported formats',
  tableHeaders: ['Format', 'Typical use', 'Transparency', 'Compression type'],
  rows: [
    ['JPG / JPEG', 'Photos, social sharing', 'No', 'Lossy'],
    ['PNG', 'UI assets, logos, screenshots', 'Yes', 'Lossless'],
    ['WebP', 'Modern web delivery', 'Yes', 'Lossy / Lossless'],
    ['HEIC / HEIF', 'Mobile photos, storage efficiency', 'Limited by source/codec', 'High-efficiency (lossy in standard camera output)'],
    ['AVIF', 'High compression web images', 'Yes', 'Lossy / Lossless'],
  ],
  quickRecommendations: 'Quick recommendations',
  recommendations: [
    'Choose JPG for broad compatibility and smaller files for photos.',
    'Choose PNG when you need sharp text or transparent backgrounds.',
    'Choose WebP or AVIF for better web compression when target browsers support them.',
    'Use quality sliders to balance file size and visible detail.',
  ],
  commonConversionPaths: 'Common conversion paths',
  conversionPaths: [
    'HEIC to JPG: easier sharing across legacy apps and websites.',
    'PNG to JPG: reduce file size for photographic content.',
    'JPG to WebP: reduce web delivery size at equivalent visual quality.',
    'WebP to HEIF: compatibility workflows for specific mobile ecosystems.',
  ],
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  url: canonical,
  inLanguage: lang,
  datePublished,
  dateModified,
  author: { '@type': 'Organization', name: 'PicShift' },
  publisher: { '@type': 'Organization', name: 'PicShift', url: 'https://picshift.app' },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: docsUi.home,
      item: htmlCanonicalUrl(`https://picshift.app/${lang}`),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: docsUi.docs,
      item: docsHubUrl,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonical,
    },
  ],
};
const faqs = getDocsFaqs(lang, 'format-compatibility');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />

  <main class="flex-1">
    <article class="max-w-4xl mx-auto px-4 py-10 sm:py-14">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-text-secondary">
        <a href={localePath('/', lang)} class="hover:text-text-primary hover:underline">{docsUi.home}</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/docs`} class="hover:text-text-primary hover:underline">{docsUi.docs}</a>
        <span class="mx-2">/</span>
        <span class="text-text-primary">{docsUi.formatDocTitle}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        {title}
      </h1>
      <p class="text-base sm:text-lg text-text-secondary mb-8">
        {formatDocContent.intro}
      </p>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{formatDocContent.supportedFormats}</h2>
        <div class="overflow-x-auto rounded-xl border border-border bg-card-bg shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{formatDocContent.tableHeaders[0]}</th>
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{formatDocContent.tableHeaders[1]}</th>
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{formatDocContent.tableHeaders[2]}</th>
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{formatDocContent.tableHeaders[3]}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border text-text-secondary">
              {formatDocContent.rows.map((row) => (
                <tr>
                  <td class="py-3 px-4 text-text-primary font-medium">{row[0]}</td>
                  <td class="py-3 px-4">{row[1]}</td>
                  <td class="py-3 px-4">{row[2]}</td>
                  <td class="py-3 px-4">{row[3]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{formatDocContent.quickRecommendations}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {formatDocContent.recommendations.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{formatDocContent.commonConversionPaths}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {formatDocContent.conversionPaths.map((pathItem) => (
            <li>{pathItem}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.faq}</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="rounded-xl border border-border bg-card-bg p-4">
              <h3 class="text-base font-semibold text-text-primary mb-1">{faq.q}</h3>
              <p class="text-sm text-text-secondary">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.relatedPages}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          <li><a href={`/${lang}/docs/privacy-local-processing`} class="text-primary-500 hover:underline">{docsUi.privacyDocTitle}</a></li>
          <li><a href={`/${lang}/docs/image-quality-vs-file-size`} class="text-primary-500 hover:underline">{docsUi.qualityDocTitle}</a></li>
          <li><a href={`/${lang}/docs`} class="text-primary-500 hover:underline">{docsUi.allDocs}</a></li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.backToToolPages}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          <li><a href={`/${lang}/heic-to-jpg`} class="text-primary-500 hover:underline">{pageTranslations.tools['heic-to-jpg']?.h1 || 'HEIC to JPG Converter'}</a></li>
          <li><a href={`/${lang}/jpg-to-webp`} class="text-primary-500 hover:underline">{pageTranslations.tools['jpg-to-webp']?.h1 || 'JPG to WebP Converter'}</a></li>
          <li><a href={`/${lang}/png-to-jpg`} class="text-primary-500 hover:underline">{pageTranslations.tools['png-to-jpg']?.h1 || 'PNG to JPG Converter'}</a></li>
        </ul>
      </section>
      <p class="text-sm text-text-secondary pt-4 border-t border-border">{docsUi.lastUpdated}: {dateModified}</p>
    </article>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </main>

  <Footer lang={lang} />
</Layout>
