---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import { CONTENT_DATE_MODIFIED, DOCS_DATE_PUBLISHED } from '../../../lib/contentDates';
import { getDocsFaqs } from '../../../i18n/docsFaqs';
import { getDocsUi } from '../../../i18n/docsUi';
import { SUPPORTED_LOCALES, localePath } from '../../../i18n';
import { getPageTranslations } from '../../../i18n/translations';
import { getVerificationUi } from '../../../i18n/verificationUi';
import type { Locale } from '../../../i18n/config';
import { htmlCanonicalUrl } from '../../../lib/htmlCanonicalUrl';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== 'en')
    .map((l) => ({
      params: { lang: l },
      props: { lang: l },
    }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const docsUi = getDocsUi(lang);
const verifyUi = getVerificationUi(lang);
const pageTranslations = getPageTranslations(lang);
const title = `PicShift ${docsUi.privacyDocTitle}`;
const description = docsUi.privacyDocDescription;
const pagePath = '/docs/privacy-local-processing';
const docsHubUrl = htmlCanonicalUrl(`https://picshift.app/${lang}/docs`);
const canonical = htmlCanonicalUrl(`https://picshift.app/${lang}/docs/privacy-local-processing`);
const datePublished = DOCS_DATE_PUBLISHED;
const dateModified = CONTENT_DATE_MODIFIED;
