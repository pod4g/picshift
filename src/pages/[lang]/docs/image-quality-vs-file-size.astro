import { SUPPORTED_LOCALES } from '../../../i18n';
import { getPageTranslations } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/config';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== 'en')
    .map((l) => ({
      params: { lang: l },
      props: { lang: l },
    }));
}

interface Props {
