  pt: 'Se o arquivo convertido aumentar, a causa pode ser comportamento do formato, compressao previa intensa ou ambos. Veja',
  ru: 'Если после конвертации размер вырос, причиной может быть поведение формата, глубокая исходная компрессия или оба фактора. См.',
  ar: 'إذا زاد الحجم بعد التحويل فقد يكون السبب خصائص الصيغة أو ضغطا عميقا مسبقا أو السببين معا. راجع',
  it: 'Se il file convertito aumenta, la causa puo essere il comportamento del formato, una forte compressione gia presente o entrambi. Vedi',
  en: 'If converted size increases, it can come from format behavior, deep prior compression, or both. See',
}[lang] ?? 'If converted size increases, it can come from format behavior, deep prior compression, or both. See';
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description,
  url: canonical,
  inLanguage: lang,
  datePublished,
  dateModified,
  author: { '@type': 'Organization', name: 'PicShift' },
  publisher: { '@type': 'Organization', name: 'PicShift', url: 'https://picshift.app' },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: docsUi.home,
      item: `https://picshift.app/${lang}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: docsUi.docs,
      item: `https://picshift.app/${lang}/docs`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: canonical,
    },
  ],
};
const faqs = getDocsFaqs(lang, 'image-quality-vs-file-size');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.a,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />

  <main class="flex-1">
    <article class="max-w-3xl mx-auto px-4 py-10 sm:py-14">
      <nav aria-label="Breadcrumb" class="mb-4 text-sm text-text-secondary">
        <a href={`/${lang}/`} class="hover:text-text-primary hover:underline">{docsUi.home}</a>
        <span class="mx-2">/</span>
        <a href={`/${lang}/docs`} class="hover:text-text-primary hover:underline">{docsUi.docs}</a>
        <span class="mx-2">/</span>
        <span class="text-text-primary">{docsUi.qualityDocTitle}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-bold text-text-primary mb-4">
        {title}
      </h1>
      <p class="text-base sm:text-lg text-text-secondary mb-8">
        {qualityDocContent.intro}
      </p>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{qualityDocContent.presetsHeading}</h2>
        <div class="overflow-x-auto rounded-xl border border-border bg-card-bg shadow-sm">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{qualityDocContent.tableHeaders[0]}</th>
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{qualityDocContent.tableHeaders[1]}</th>
                <th class="text-left py-3 px-4 font-medium text-text-secondary">{qualityDocContent.tableHeaders[2]}</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border text-text-secondary">
              {qualityDocContent.rows.map((row) => (
                <tr>
                  <td class="py-3 px-4 text-text-primary font-medium">{row[0]}</td>
                  <td class="py-3 px-4">{row[1]}</td>
                  <td class="py-3 px-4">{row[2]}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{qualityDocContent.tipsHeading}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          {qualityDocContent.tips.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.sizeIncreaseDocTitle}</h2>
        <p class="text-text-secondary">
          {sizeIncreaseExplainMap}
          {' '}
          <a href={`/${lang}/docs/size-increase-explainer`} class="text-primary-500 hover:underline">{docsUi.sizeIncreaseDocTitle}</a>
          .
        </p>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{qualityDocContent.workflowHeading}</h2>
        <ol class="list-decimal pl-5 space-y-2 text-text-secondary">
          {qualityDocContent.workflow.map((item) => (
            <li>{item}</li>
          ))}
        </ol>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.faq}</h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="rounded-xl border border-border bg-card-bg p-4">
              <h3 class="text-base font-semibold text-text-primary mb-1">{faq.q}</h3>
              <p class="text-sm text-text-secondary">{faq.a}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.relatedPages}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          <li><a href={`/${lang}/docs/size-increase-explainer`} class="text-primary-500 hover:underline">{docsUi.sizeIncreaseDocTitle}</a></li>
          <li><a href={`/${lang}/docs/format-compatibility`} class="text-primary-500 hover:underline">{docsUi.formatDocTitle}</a></li>
          <li><a href={`/${lang}/docs/privacy-local-processing`} class="text-primary-500 hover:underline">{docsUi.privacyDocTitle}</a></li>
          <li><a href={`/${lang}/docs`} class="text-primary-500 hover:underline">{docsUi.allDocs}</a></li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl sm:text-2xl font-semibold text-text-primary mb-3">{docsUi.backToToolPages}</h2>
        <ul class="list-disc pl-5 space-y-2 text-text-secondary">
          <li><a href={`/${lang}/image-compressor`} class="text-primary-500 hover:underline">{pageTranslations.tools['image-compressor']?.h1 || 'Image Compressor'}</a></li>
          <li><a href={`/${lang}/jpg-to-webp`} class="text-primary-500 hover:underline">{pageTranslations.tools['jpg-to-webp']?.h1 || 'JPG to WebP Converter'}</a></li>
          <li><a href={`/${lang}/png-to-jpg`} class="text-primary-500 hover:underline">{pageTranslations.tools['png-to-jpg']?.h1 || 'PNG to JPG Converter'}</a></li>
        </ul>
      </section>
      <p class="text-sm text-text-secondary pt-4 border-t border-border">{docsUi.lastUpdated}: {dateModified}</p>
    </article>
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </main>

  <Footer lang={lang} />
</Layout>
