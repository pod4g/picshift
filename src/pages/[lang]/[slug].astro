---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import PrivacyBadge from '../../components/seo/PrivacyBadge.astro';
import HowTo from '../../components/seo/HowTo.astro';
import FAQ from '../../components/seo/FAQ.astro';
import Converter from '../../components/converter/Converter';
import MetadataRemoverTool from '../../components/metadata/MetadataRemoverTool';
import { TOOL_PAGES } from '../../data/tools';
import { SUPPORTED_LOCALES, localePath } from '../../i18n';
import { getPageTranslations } from '../../i18n/translations';
import { getUI } from '../../i18n/ui';
import { getDocsUi } from '../../i18n/docsUi';
import { getLocalizedToolMeta } from '../../i18n/toolMeta';
import { getToolPageUi } from '../../i18n/toolPageUi';
import { getLocalizedToolContent } from '../../i18n/toolContent';
import { getLocalizedToolSearchIntentSections } from '../../i18n/toolSearchIntent';
import type { Locale } from '../../i18n/config';
import type { ToolPageConfig } from '../../types';
import { htmlCanonicalUrl } from '../../lib/htmlCanonicalUrl';
import { buildToolSoftwareApplicationSchema } from '../../lib/softwareApplicationSchema';

export function getStaticPaths() {
  const paths: Array<{ params: { lang: string; slug: string }; props: { lang: Locale; tool: ToolPageConfig } }> = [];
  for (const locale of SUPPORTED_LOCALES) {
    if (locale === 'en') continue;
    for (const tool of TOOL_PAGES) {
      paths.push({
        params: { lang: locale, slug: tool.slug },
        props: { lang: locale, tool },
      });
    }
  }
  return paths;
}

interface Props {
  lang: Locale;
  tool: ToolPageConfig;
}

const { lang, tool } = Astro.props;
const canonical = htmlCanonicalUrl(`https://picshift.app/${lang}/${tool.slug}`);
const pagePath = `/${tool.slug}`;
const pageTranslations = getPageTranslations(lang);
const toolTranslation = pageTranslations.tools[tool.slug];
const localizedMeta = getLocalizedToolMeta(lang, tool);
const localizedContent = getLocalizedToolContent(lang, tool);

const title = toolTranslation?.title || localizedMeta.title;
const description = toolTranslation?.description || localizedMeta.description;
const h1 = toolTranslation?.h1 || localizedContent.h1;
const introText = toolTranslation?.introText || localizedContent.introText;
const howToSteps = toolTranslation?.howToSteps || localizedContent.howToSteps;
const t = getUI(lang);
const docsUi = getDocsUi(lang);
const toolPageUi = getToolPageUi(lang);
const sizeIncreaseDocUrl = htmlCanonicalUrl(`https://picshift.app/${lang}/docs/size-increase-explainer`);
const sizeIncreaseFaqLinkTextMap: Record<Locale, string> = {
  en: 'Learn more:',
  zh: '详细说明：',
  'zh-Hant': '詳細說明：',
  es: 'Mas detalles:',
  fr: 'En savoir plus :',
  de: 'Mehr dazu:',
  ja: '詳しくはこちら：',
  ko: '자세히 보기:',
  pt: 'Saiba mais:',
  ru: 'Подробнее:',
  ar: 'تفاصيل اكثر:',
  it: 'Maggiori dettagli:',
};
const faqs = [
  ...localizedContent.faqs,
  ...(tool.slug === 'metadata-remover'
    ? []
    : [
        {
          q: t.sizeIncreaseFaqQ,
          a: `${t.sizeIncreaseFaqA} ${sizeIncreaseFaqLinkTextMap[lang]} ${sizeIncreaseDocUrl}`,
        },
      ]),
];
const fallbackRelatedToolSlugs = ['image-compressor', 'image-resizer', 'png-to-jpg', 'jpg-to-png'];
const HEIC_SUITE_SLUGS = [
  'heic-to-jpg',
  'heic-to-png',
  'heic-to-webp',
  'heic-to-avif',
  'heif-to-jpg',
  'heif-to-png',
  'heif-to-webp',
  'heif-to-avif',
] as const;
const isHeicSuitePage = (HEIC_SUITE_SLUGS as readonly string[]).includes(tool.slug);

function pickRelatedTools(currentTool: ToolPageConfig): ToolPageConfig[] {
  const reverse = TOOL_PAGES.find(
    (candidate) =>
      candidate.slug !== currentTool.slug &&
      candidate.defaultInputFormat === currentTool.defaultOutputFormat &&
      candidate.defaultOutputFormat === currentTool.defaultInputFormat
  );
  const sameInput = TOOL_PAGES.filter(
    (candidate) => candidate.slug !== currentTool.slug && candidate.defaultInputFormat === currentTool.defaultInputFormat
  );
  const sameOutput = TOOL_PAGES.filter(
    (candidate) => candidate.slug !== currentTool.slug && candidate.defaultOutputFormat === currentTool.defaultOutputFormat
  );
  const fallbackTools = fallbackRelatedToolSlugs
    .map((slug) => TOOL_PAGES.find((candidate) => candidate.slug === slug))
    .filter((candidate): candidate is ToolPageConfig => Boolean(candidate));

  const orderedCandidates = [reverse, ...sameInput, ...sameOutput, ...fallbackTools].filter(
    (candidate): candidate is ToolPageConfig => Boolean(candidate)
  );
  const uniqueBySlug = new Map<string, ToolPageConfig>();
  for (const candidate of orderedCandidates) {
    if (candidate.slug === currentTool.slug) continue;
    if (!uniqueBySlug.has(candidate.slug)) uniqueBySlug.set(candidate.slug, candidate);
    if (uniqueBySlug.size >= 4) break;
  }

  return [...uniqueBySlug.values()];
}

function pickHeicSuiteTools(currentSlug: string): ToolPageConfig[] {
  return HEIC_SUITE_SLUGS.filter((slug) => slug !== currentSlug)
    .map((slug) => TOOL_PAGES.find((candidate) => candidate.slug === slug))
    .filter((candidate): candidate is ToolPageConfig => Boolean(candidate));
}

// Authority-pin: every entry concentrates internal PageRank onto the
// single page in that locale that most needs a ranking push. HEIC-suite
// pages keep their theme-specific cluster links because those already
// concentrate authority onto the HEIC family.
//
// es → image-resizer : 550+ imp stuck at rank 60-80 on
//   "redimensionar imagen", "cambiar tamaño de imagen"
// pt → jpg-to-png : 800+ imp stuck at rank 55-60 on 10 Portuguese
//   variants of "converter/conversor/transformar jpg em/para png"
// fr → image-resizer : 108 imp at rank 28 on
//   "redimensionner image en ligne" — near-win that a pin can push into
//   the top 20
const AUTHORITY_PINS_BY_LANG: Partial<Record<Locale, readonly string[]>> = {
  es: ['image-resizer'],
  pt: ['jpg-to-png'],
  fr: ['image-resizer'],
};
const AUTHORITY_EXEMPT_SLUGS = new Set<string>([
  'image-resizer',
  'image-compressor',
  'metadata-remover',
]);

function applyAuthorityPin(
  candidates: ToolPageConfig[],
  pinSlugs: readonly string[],
  targetSize: number
): ToolPageConfig[] {
  const pinned: ToolPageConfig[] = [];
  for (const slug of pinSlugs) {
    const tool = TOOL_PAGES.find((candidate) => candidate.slug === slug);
    if (tool && !pinned.some((p) => p.slug === tool.slug)) pinned.push(tool);
  }
  const withoutPinned = candidates.filter(
    (candidate) => !pinned.some((p) => p.slug === candidate.slug)
  );
  return [...pinned, ...withoutPinned].slice(0, targetSize);
}

const baseRelatedCandidates = isHeicSuitePage
  ? pickHeicSuiteTools(tool.slug)
  : pickRelatedTools(tool);
const authorityPinsForLang = AUTHORITY_PINS_BY_LANG[lang] ?? [];
// A pinned page cannot self-link (that would fill the first related-tool
// slot with its own href). Also skip pinning on the tool-type authority
// pages (image-resizer/compressor/metadata-remover) because they already
// sit above converters in the IA.
const isCurrentPagePinned = authorityPinsForLang.includes(tool.slug);
const shouldApplyAuthorityPin =
  !isHeicSuitePage &&
  authorityPinsForLang.length > 0 &&
  !AUTHORITY_EXEMPT_SLUGS.has(tool.slug) &&
  !isCurrentPagePinned;
const relatedToolCandidates = shouldApplyAuthorityPin
  ? applyAuthorityPin(baseRelatedCandidates, authorityPinsForLang, 4)
  : baseRelatedCandidates;
const relatedTools = relatedToolCandidates.map((relatedTool) => {
  const relatedTranslation = pageTranslations.tools[relatedTool.slug];
  const relatedContent = getLocalizedToolContent(lang, relatedTool);
  return {
    href: localePath(`/${relatedTool.slug}`, lang),
    title: relatedTranslation?.h1 || relatedContent.h1,
  };
});
const relatedToolsHeading = isHeicSuitePage ? toolPageUi.heicSuiteTitle : toolPageUi.relatedTools;
const limitationItems = [toolPageUi.limitationFormat, toolPageUi.limitationSize, toolPageUi.limitationCompatibility];
const detailSections = toolTranslation?.detailSections || [];
const searchIntentSections = getLocalizedToolSearchIntentSections(lang, tool);
const showGenericLimitations = tool.slug !== 'metadata-remover';
const showHowTo = tool.slug !== 'metadata-remover';
const relatedGuides = [
  {
    href: localePath('/docs/format-compatibility', lang),
    title: docsUi.formatDocTitle,
  },
  {
    href: localePath('/docs/image-quality-vs-file-size', lang),
    title: docsUi.qualityDocTitle,
  },
  {
    href: localePath('/docs/size-increase-explainer', lang),
    title: docsUi.sizeIncreaseDocTitle,
  },
  {
    href: localePath('/docs/privacy-local-processing', lang),
    title: docsUi.privacyDocTitle,
  },
];

const localizedHomeUrl = htmlCanonicalUrl(`https://picshift.app/${lang}`);
const softwareApplicationSchema = buildToolSoftwareApplicationSchema({
  tool,
  h1,
  description,
  canonical,
  lang,
});
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: docsUi.home,
      item: localizedHomeUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: h1,
      item: canonical,
    },
  ],
};
const relatedGuidesItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${h1} ${docsUi.relatedPages}`,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: relatedGuides.length,
  itemListElement: relatedGuides.map((guide, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: guide.title,
    url: htmlCanonicalUrl(`https://picshift.app${guide.href}`),
  })),
};
const relatedToolsItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${h1} ${relatedToolsHeading}`,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: relatedTools.length,
  itemListElement: relatedTools.map((relatedTool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: relatedTool.title,
    url: htmlCanonicalUrl(`https://picshift.app${relatedTool.href}`),
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />

  <main class="flex-1">
    <div class="max-w-5xl mx-auto px-4 py-6 sm:py-8">
      <!-- Page heading -->
      <div class="mb-5 sm:mb-6">
        <nav aria-label="Breadcrumb" class="mb-3 text-sm text-text-secondary">
          <a href={localePath('/', lang)} class="hover:text-text-primary hover:underline">{docsUi.home}</a>
          <span class="mx-2">/</span>
          <span class="text-text-primary">{h1}</span>
        </nav>
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text-primary mb-2 sm:mb-3">
          {h1}
        </h1>
        <p class="text-base sm:text-lg text-text-secondary max-w-2xl">
          {introText}
        </p>
      </div>

      <!-- Privacy badge -->
      <div class="mb-6">
        <PrivacyBadge lang={lang} />
      </div>

      <!-- Tool island -->
      <div class="bg-card-bg rounded-xl border border-border shadow-sm p-4 md:p-6 mb-8">
        {tool.slug === 'metadata-remover' ? (
          <MetadataRemoverTool client:load lang={lang} />
        ) : (
          <Converter
            client:load
            defaultInputFormat={tool.defaultInputFormat}
            defaultOutputFormat={tool.defaultOutputFormat}
            keepSmaller={tool.slug === 'image-compressor'}
            resizeDefault={tool.slug === 'image-resizer'}
            lang={lang}
          />
        )}
      </div>

      <!-- How-to section -->
      {showHowTo && <HowTo steps={howToSteps} toolName={h1} lang={lang} />}

      {detailSections.length > 0 && (
        <section class="mb-8">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {detailSections.map((section) => (
              <article class="rounded-xl border border-border bg-card-bg p-4 sm:p-5 shadow-sm">
                <h2 class="text-lg sm:text-xl font-semibold text-text-primary mb-2">{section.title}</h2>
                <p class="text-sm text-text-secondary leading-6 mb-3">{section.body}</p>
                {section.items && section.items.length > 0 && (
                  <ul class="list-disc pl-5 space-y-2 text-sm text-text-secondary">
                    {section.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
        </section>
      )}

      {searchIntentSections.length > 0 && (
        <section class="mb-8">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            {searchIntentSections.map((section) => (
              <article class="rounded-xl border border-border bg-card-bg p-4 sm:p-5 shadow-sm">
                <h2 class="text-lg sm:text-xl font-semibold text-text-primary mb-2">{section.title}</h2>
                <p class="text-sm text-text-secondary leading-6">{section.body}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      {showGenericLimitations && (
        <section class="mb-8">
          <div class="rounded-xl border border-border bg-card-bg p-4 sm:p-5">
            <h2 class="text-lg sm:text-xl font-semibold text-text-primary mb-2">{toolPageUi.limitations}</h2>
            <p class="text-sm text-text-secondary mb-3">{toolPageUi.limitationsIntro}</p>
            <ul class="list-disc pl-5 space-y-2 text-sm text-text-secondary">
              {limitationItems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </section>
      )}

      <section class="mb-8">
        <div class="rounded-xl border border-border bg-card-bg p-4 sm:p-5">
          <h2 class="text-lg sm:text-xl font-semibold text-text-primary mb-3">{relatedToolsHeading}</h2>
          <div class="flex flex-wrap gap-2">
            {relatedTools.map((relatedTool) => (
              <a
                href={relatedTool.href}
                class="inline-flex items-center rounded-lg border border-border px-3 py-1.5 text-sm text-text-secondary hover:text-text-primary hover:bg-drop-bg transition-colors"
              >
                {relatedTool.title}
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="mb-8">
        <div class="rounded-xl border border-border bg-card-bg p-4 sm:p-5">
          <h2 class="text-lg sm:text-xl font-semibold text-text-primary mb-3">{docsUi.relatedPages}</h2>
          <div class="flex flex-wrap gap-2">
            {relatedGuides.map((guide) => (
              <a
                href={guide.href}
                class="inline-flex items-center rounded-lg border border-border px-3 py-1.5 text-sm text-text-secondary hover:text-text-primary hover:bg-drop-bg transition-colors"
              >
                {guide.title}
              </a>
            ))}
          </div>
        </div>
      </section>

      <script type="application/ld+json" set:html={JSON.stringify(softwareApplicationSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(relatedToolsItemListSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(relatedGuidesItemListSchema)} />

      <!-- FAQ section -->
      <FAQ faqs={faqs} lang={lang} />
    </div>
  </main>

  <Footer lang={lang} />
</Layout>
