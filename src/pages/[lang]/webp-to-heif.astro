---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { SUPPORTED_LOCALES } from '../../i18n';
import type { Locale } from '../../i18n/config';
import { htmlCanonicalUrl } from '../../lib/htmlCanonicalUrl';

export function getStaticPaths() {
  return SUPPORTED_LOCALES
    .filter((l) => l !== 'en')
    .map((l) => ({
      params: { lang: l },
      props: { lang: l },
    }));
}

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const pagePath = '/webp-to-heif';
const canonical = htmlCanonicalUrl(`https://picshift.app/${lang}/webp-to-heif`);

const localized: Record<Locale, {
  title: string;
  description: string;
  h1: string;
  lead: string;
  alternativesTitle: string;
  alternatives: string[];
  faqTitle: string;
  faq: Array<{ q: string; a: string }>;
}> = {
  en: {
    title: 'WebP to HEIF Converter - Support Status & Best Alternatives | PicShift',
    description: "Need to convert WebP to HEIF/HEIC? PicShift currently doesn't export HEIF. See when WebP to HEIF is needed and use alternatives.",
    h1: 'WebP to HEIF: Is It Supported?',
    lead: 'PicShift currently does not export .heif/.heic. It supports HEIC/HEIF input, and outputs JPG, PNG, WebP, and AVIF.',
    alternativesTitle: 'Best alternatives right now',
    alternatives: [
      'WebP to JPG for widest compatibility',
      'WebP to PNG for lossless workflows',
      'Image Compressor to reduce size before sharing',
    ],
    faqTitle: 'FAQ',
    faq: [
      { q: 'Can PicShift convert WebP to HEIF?', a: 'Not yet. HEIC/HEIF are supported as input formats, but export currently supports JPG, PNG, WebP, and AVIF.' },
      { q: 'When is WebP to HEIF needed?', a: 'When a workflow specifically requires HEIF/HEIC files, especially in Apple ecosystem scenarios.' },
    ],
  },
  zh: {
    title: 'WebP 转 HEIF - 支持状态与替代方案 | PicShift',
