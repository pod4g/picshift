    alternatives: [
      'WebP para JPG para maior compatibilidade',
      'WebP para PNG para fluxo sem perdas',
      'Compressor de imagem para reduzir o tamanho antes de compartilhar',
    ],
    faqTitle: 'FAQ',
    faq: [
      { q: 'O PicShift converte WebP para HEIF?', a: 'Ainda não. HEIC/HEIF é suportado como entrada, mas a exportação atual é JPG, PNG, WebP e AVIF.' },
