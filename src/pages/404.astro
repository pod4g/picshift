---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<Layout title="Page Not Found (404) — Try our Image Tools | PicShift" description="That page is missing or has moved. Jump back to the PicShift home or try the image compressor, resizer, HEIC to JPG, or PNG to JPG converters — all run privately in your browser." lang="en" pagePath="/404">
  <Header lang="en" pagePath="/404" languageSwitchMode="locale-home" />

  <main class="flex-1 flex items-center justify-center px-4">
    <div class="text-center max-w-md py-20">
      <p class="text-7xl font-bold text-primary-400 mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl font-bold text-text-primary mb-3">Page not found</h1>
      <p class="text-text-secondary mb-8 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary-500 text-white font-medium hover:bg-primary-600 transition-colors"
        >
          Go to Homepage
        </a>
        <a
          href="/blog"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-border text-text-secondary hover:text-text-primary hover:border-text-secondary transition-colors"
        >
          Read Blog
        </a>
      </div>
    </div>
  </main>

  <Footer lang="en" />
</Layout>
