---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { htmlCanonicalUrl } from '../lib/htmlCanonicalUrl';

const lang = 'en' as const;
const pagePath = '/webp-to-heif';
const canonical = htmlCanonicalUrl('https://picshift.app/webp-to-heif');

const title = 'WebP to HEIF Converter - Support Status & Best Alternatives | PicShift';
const description =
  "Need to convert WebP to HEIF/HEIC? PicShift currently doesn't export HEIF. See when WebP to HEIF is needed and use WebP to JPG/PNG/AVIF alternatives.";

const faq = [
  {
    q: 'Can PicShift convert WebP to HEIF?',
    a: "Not yet. PicShift supports HEIC/HEIF as input, but current output formats are JPG, PNG, WebP, and AVIF.",
  },
  {
    q: 'When do I need WebP to HEIF conversion?',
    a: 'Usually when a workflow specifically requires HEIF/HEIC files for Apple ecosystem compatibility, photo library import rules, or internal delivery standards.',
  },
  {
    q: 'What should I use instead of WebP to HEIF?',
    a: 'For maximum compatibility, convert WebP to JPG. If you need lossless output, convert to PNG. If you want modern compression, convert to AVIF.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://picshift.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'WebP to HEIF',
      item: canonical,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text-primary mb-4">
        WebP to HEIF: Is It Supported?
      </h1>
      <p class="text-text-secondary text-base sm:text-lg mb-6">
        PicShift currently does not export <code>.heif</code> or <code>.heic</code>. We support HEIC/HEIF input, and output to JPG, PNG, WebP, and AVIF.
      </p>

      <section class="mb-6 bg-card-bg border border-border rounded-xl p-4 sm:p-5">
        <h2 class="text-xl font-semibold text-text-primary mb-2">Best alternatives right now</h2>
        <ul class="list-disc list-inside text-text-secondary space-y-1">
          <li><a class="text-primary-500 hover:underline" href="/webp-to-jpg">WebP to JPG</a> for widest compatibility.</li>
          <li><a class="text-primary-500 hover:underline" href="/webp-to-png">WebP to PNG</a> for lossless workflows.</li>
          <li><a class="text-primary-500 hover:underline" href="/image-compressor">Image Compressor</a> for smaller file size before sharing.</li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-text-primary">FAQ</h2>
        {faq.map((item) => (
          <article class="bg-card-bg border border-border rounded-xl p-4 sm:p-5">
            <h3 class="font-semibold text-text-primary mb-2">{item.q}</h3>
            <p class="text-text-secondary">{item.a}</p>
          </article>
        ))}
      </section>

      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
