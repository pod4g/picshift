---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const lang = 'en' as const;
const pagePath = '/jpg-png-to-heic';
const canonical = 'https://picshift.app/jpg-png-to-heic';

const title = 'JPG/PNG to HEIC or HEIF - Support Status & Alternatives | PicShift';
const description =
  "Need JPG or PNG to HEIC/HEIF conversion? PicShift currently doesn't export HEIC/HEIF. See practical alternatives for smaller files and compatibility.";

const faq = [
  {
    q: 'Can PicShift convert JPG to HEIC or HEIF?',
    a: 'Not yet. PicShift currently supports exporting JPG, PNG, WebP, and AVIF.',
  },
  {
    q: 'Can PicShift convert PNG to HEIC or HEIF?',
    a: 'Not yet. HEIC/HEIF are supported as input formats, but not as output formats.',
  },
  {
    q: 'What should I use instead?',
    a: 'Use JPG or PNG to AVIF for modern compression. For broad compatibility, use JPG. For lossless quality, use PNG.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://picshift.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'JPG/PNG to HEIC',
      item: canonical,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout title={title} description={description} canonical={canonical} lang={lang} pagePath={pagePath}>
  <Header lang={lang} pagePath={pagePath} />
  <main class="flex-1">
    <div class="max-w-3xl mx-auto px-4 py-8 sm:py-12">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text-primary mb-4">
        JPG/PNG to HEIC/HEIF: Is It Supported?
      </h1>
      <p class="text-text-secondary text-base sm:text-lg mb-6">
        PicShift currently does not export <code>.heic</code> or <code>.heif</code>. It supports HEIC/HEIF input, and outputs JPG, PNG, WebP, and AVIF.
      </p>

      <section class="mb-6 bg-card-bg border border-border rounded-xl p-4 sm:p-5">
        <h2 class="text-xl font-semibold text-text-primary mb-2">Best alternatives right now</h2>
        <ul class="list-disc list-inside text-text-secondary space-y-1">
          <li><a class="text-primary-500 hover:underline" href="/image-compressor">Image Compressor</a> for reducing JPG/PNG size before sharing.</li>
          <li><a class="text-primary-500 hover:underline" href="/jpg-to-webp">JPG to WebP</a> for smaller web-friendly files.</li>
          <li><a class="text-primary-500 hover:underline" href="/jpg-to-png">JPG to PNG</a> or <a class="text-primary-500 hover:underline" href="/png-to-jpg">PNG to JPG</a> for compatibility workflows.</li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-text-primary">FAQ</h2>
        {faq.map((item) => (
          <article class="bg-card-bg border border-border rounded-xl p-4 sm:p-5">
            <h3 class="font-semibold text-text-primary mb-2">{item.q}</h3>
            <p class="text-text-secondary">{item.a}</p>
          </article>
        ))}
      </section>

      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
